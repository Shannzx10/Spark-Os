#!/bin/sh
clear

# ── Kumpulkan info sistem ─────────────────────────────────
MYHOST=$(cat /etc/hostname 2>/dev/null || echo "Spark-OS")
KERNEL=$(uname -r 2>/dev/null || echo "unknown")
ARCH=$(uname -m 2>/dev/null || echo "unknown")
USER_NAME=$(whoami 2>/dev/null || echo "root")
SHELL_NAME=$(basename "${SHELL:-/bin/sh}")

if [ -f /proc/meminfo ] && [ -r /proc/meminfo ]; then
  MEM_TOTAL=$(awk '/MemTotal/{printf "%.0f", $2/1024}' /proc/meminfo)
  MEM_AVAIL=$(awk '/MemAvailable/{printf "%.0f", $2/1024}' /proc/meminfo)
  MEM_USED=$((MEM_TOTAL - MEM_AVAIL))
  MEM_INFO="${MEM_USED} MB / ${MEM_TOTAL} MB"
else
  MEM_INFO="unavailable"
fi

if [ -f /proc/uptime ] && [ -r /proc/uptime ]; then
  S=$(cut -d. -f1 /proc/uptime)
  D=$((S / 86400)); S=$((S % 86400))
  H=$((S / 3600));  S=$((S % 3600))
  M=$((S / 60))
  [ "$D" -gt 0 ] && UPTIME="${D}d ${H}h ${M}m" \
  || { [ "$H" -gt 0 ] && UPTIME="${H}h ${M}m" || UPTIME="${M}m"; }
else
  UPTIME="unavailable"
fi

DATE=$(date '+%a, %d %b %Y')
TIME=$(date '+%H:%M:%S %Z')

# ── Warna ─────────────────────────────────────────────────
CY='\e[1;36m'
GR='\e[1;32m'
YE='\e[1;33m'
WH='\e[1;37m'
MA='\e[1;35m'
DM='\e[2;37m'
RS='\e[0m'

# ── Helper ────────────────────────────────────────────────
# Lebar kotak: 2 + label(10) + ": " (2) + value(32) + " " (1) = 47
# Border pakai 47x ═

row() {
  L=$(printf '%-10s' "$1")
  V=$(printf '%-32s' "$2")
  echo -e "  ${GR}║${RS}  ${WH}${L}${RS}: ${YE}${V}${RS} ${GR}║${RS}"
}

row_hi() {
  L=$(printf '%-10s' "$1")
  V=$(printf '%-32s' "$2")
  echo -e "  ${GR}║${RS}  ${MA}${L}${RS}: ${WH}${V}${RS} ${GR}║${RS}"
}

SEP_TOP="  ${GR}╔═══════════════════════════════════════════════╗${RS}"
SEP_MID="  ${GR}╠═══════════════════════════════════════════════╣${RS}"
SEP_BOT="  ${GR}╚═══════════════════════════════════════════════╝${RS}"

# ── ASCII Art ─────────────────────────────────────────────
echo -e "${CY}"
echo "   ____                   _      ___  ____  "
echo "  / ___| _ __   __ _ _ __| | __ / _ \/ ___| "
echo "  \___ \| '_ \ / _\` | '__| |/ /| | | \___ \\"
echo "   ___) | |_) | (_| | |  |   < | |_| |___) |"
echo "  |____/| .__/ \__,_|_|  |_|\_\ \___/|____/ "
echo -e "        |_|                          ${GR}v1.0${RS}"
echo ""

# ── Info Panel ────────────────────────────────────────────
echo -e "$SEP_TOP"
echo -e "  ${GR}║${RS}       ${WH}Spark OS ${DM}─${RS}${WH} Mini Linux Environment       ${GR}║${RS}"
echo -e "$SEP_MID"
row  "OS"      "Spark OS v1.0"
row  "Kernel"  "$KERNEL"
row  "Arch"    "$ARCH"
row  "Host"    "$MYHOST"
row  "User"    "$USER_NAME"
row  "Shell"   "$SHELL_NAME"
echo -e "$SEP_MID"
row  "Uptime"  "$UPTIME"
row  "Memory"  "$MEM_INFO"
row  "Date"    "$DATE"
row  "Time"    "$TIME"
echo -e "$SEP_MID"
row_hi "Author"  "Shannz"
row_hi "Website" "sparkos.eu.cc"
row_hi "GitHub"  "github.com/Shannzx10/Spark-Os"
echo -e "$SEP_BOT"
echo ""
